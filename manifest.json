{
  "manifest_version": 3,
  "name": "HrGang — Оценка кандидатов",
  "version": "1.0",
  "description": "Оценка резюме на hh.kz с помощью Gemini AI",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://hh.kz/*",
    "https://*.hh.kz/*",
    "https://hh.ru/*",
    "https://*.hh.ru/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://hh.kz/resume/*",
        "https://*.hh.kz/resume/*",
        "https://hh.ru/resume/*",
        "https://*.hh.ru/resume/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}